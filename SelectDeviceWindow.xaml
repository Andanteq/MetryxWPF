<Window x:Class="MetryxWPF.SelectDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MetryxWPF"
        mc:Ignorable="d"
        Title="SelectDeviceWindow" Height="450" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBox x:Name="SearchBox"
             Height="30"
             Margin="0,0,0,10"
             TextChanged="SearchBox_TextChanged"/>
        <DataGrid x:Name="DevicesGrid"
              Grid.Row="1"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              MouseDoubleClick="DevicesGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование"
                                Binding="{Binding Name}"
                                Width="*"/>
                <DataGridTextColumn Header="Тип"
                                Binding="{Binding TypeName}"
                                Width="150"/>
                <DataGridTextColumn Header="Заводской номер"
                                Binding="{Binding Serialnumber}"
                                Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,10,0,0">
            <Button Content="Выбрать"
                Width="100"
                Margin="0,0,10,0"
                Click="SelectButton_Click"/>
            <Button Content="Отмена"
                Width="100"
                Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
