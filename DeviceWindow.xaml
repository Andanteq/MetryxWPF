<Window x:Class="MetryxWPF.DeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MetryxWPF"
        xmlns:hс="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Title="DeviceWindow" Height="742" Width="833">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="130"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{Binding Name}"
                       FontSize="20" FontWeight="DemiBold"/>
            <TextBlock Grid.Row="1" FontSize="15"
                       Foreground="#707070">
                <Run Text="{Binding Type.Name}"/>
                <Run>•</Run>
                <Run Text="{Binding Serialnumber}"/>
            </TextBlock>
        </Grid>
        <Border Height="1"
                Grid.Row="0" Grid.ColumnSpan="2"
                Background="#707070"
                VerticalAlignment="Bottom"
                Margin="14, 0, 0, 0"/>
        <Button Grid.Row="0" Grid.Column="1"
                Foreground="White" Background="#030213"
                Width="120" Height="40" Click="SaveButton_Click"
                Margin="0, 0, 14, 0" hс:BorderElement.CornerRadius="7"
                FontSize="15">
            Сохранить
        </Button>
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0"
                       FontSize="20" FontWeight="DemiBold"
                       Margin="14, 10, 0, 10">
                Основная информация
            </TextBlock>
            <Border Height="1"
                    Grid.Row="0" Grid.ColumnSpan="2"
                    Background="#707070"
                    VerticalAlignment="Bottom"
                    Margin="14, 0, 0, 0"/>
            <StackPanel Grid.Row="1" Grid.Column="0">
                <TextBlock FontSize="12" FontWeight="DemiBold"
                           Margin="14, 15, 0, 0">
                    <Run Foreground="#707070">Наименование</Run>
                    <Run Foreground="Red">*</Run>
                </TextBlock>
                <TextBox x:Name="DeviceName" Margin="14, 4, 7, 0" 
                         hс:BorderElement.CornerRadius="7" 
                         BorderBrush="#c7c7c9" Background="#FFE0E0E0"
                         Text="{Binding Name}"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1">
                <TextBlock FontSize="12" FontWeight="DemiBold"
                           Margin="7, 15, 0, 0">
                    <Run Foreground="#707070">Тип прибора</Run>
                    <Run Foreground="Red">*</Run>
                </TextBlock>
                <ComboBox x:Name="DeviceType" Margin="7, 4, 0, 0" 
                          hс:BorderElement.CornerRadius="7" 
                          BorderBrush="#c7c7c9" Background="#FFE0E0E0"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="0">
                <TextBlock FontSize="12" FontWeight="DemiBold"
                           Margin="14, 15, 0, 0">
                    <Run Foreground="#707070">Заводской номер</Run>
                    <Run Foreground="Red">*</Run>
                </TextBlock>
                <TextBox x:Name="DeviceSerialnumber" Margin="14, 4, 7, 0" 
                         hс:BorderElement.CornerRadius="7" 
                         BorderBrush="#c7c7c9" Background="#FFE0E0E0"
                         Text="{Binding Serialnumber}"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1">
                <TextBlock FontSize="12" FontWeight="DemiBold"
                           Margin="7, 15, 0, 0">
                    <Run Foreground="#707070">Дата выпуска</Run>
                    <Run Foreground="Red">*</Run>
                </TextBlock>
                <DatePicker x:Name="DeviceReleaseDate" Margin="7, 4, 0, 0"
                            hс:BorderElement.CornerRadius="7" 
                            BorderBrush="#c7c7c9"
                            BorderThickness="1"
                            Background="#FFE0E0E0"
                            IsDropDownOpen="False" SelectedDateFormat="Short"
                            SelectedDate="{Binding Releasedate}">
                    <DatePicker.Resources>
                        <Style TargetType="Calendar">
                            <Setter Property="Language" Value="ru-RU"/>
                        </Style>
                        <Style TargetType="CalendarItem">
                            <Setter Property="Language" Value="ru-RU"/>
                        </Style>
                    </DatePicker.Resources>
                </DatePicker>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                       FontSize="20" FontWeight="DemiBold"
                       Margin="14, 10, 0, 10">
                Поверка
            </TextBlock>
            <Border Height="1"
                    Grid.Row="0" Grid.ColumnSpan="3"
                    Background="#707070"
                    VerticalAlignment="Bottom"
                    Margin="14, 0, 0, 0"/>
            <StackPanel Grid.Row="1" Grid.Column="0">
                <TextBlock FontSize="12" FontWeight="DemiBold"
                           Margin="14, 15, 0, 0"
                           Foreground="#707070">
                    Периодичность (мес.)
                </TextBlock>
                <TextBox x:Name="DeviceVerificationInterval" Margin="14, 4, 7, 0" 
                         hс:BorderElement.CornerRadius="7" 
                         BorderBrush="#c7c7c9" Background="#FFE0E0E0"
                         Text="{Binding Verificationinterval}"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1">
                <TextBlock FontSize="12" FontWeight="DemiBold"
                           Margin="7, 15, 0, 0">
                    <Run Foreground="#707070">Последняя поверка</Run>
                    <Run Foreground="Red">*</Run>
                </TextBlock>
                <DatePicker x:Name="DeviceLastVerificationDate" Margin="7, 4, 7, 0"
                            hс:BorderElement.CornerRadius="7" 
                            BorderBrush="#c7c7c9"
                            BorderThickness="1"
                            Background="#FFE0E0E0"
                            IsDropDownOpen="False" SelectedDateFormat="Short"
                            SelectedDate="{Binding Lastverificationdate}">
                    <DatePicker.Resources>
                        <Style TargetType="Calendar">
                            <Setter Property="Language" Value="ru-RU"/>
                        </Style>
                        <Style TargetType="CalendarItem">
                            <Setter Property="Language" Value="ru-RU"/>
                        </Style>
                    </DatePicker.Resources>
                </DatePicker>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="2">
                <TextBlock FontSize="12" FontWeight="DemiBold"
                           Margin="7, 15, 0, 0"
                           Foreground="#707070">
                    Следующая поверка
                </TextBlock>
                <DatePicker x:Name="DeviceNextVerificationDate" Margin="7, 4, 0, 0"
                            hс:BorderElement.CornerRadius="7" 
                            BorderBrush="#c7c7c9"
                            BorderThickness="1"
                            Background="#FFE0E0E0"
                            IsDropDownOpen="False" SelectedDateFormat="Short"
                            SelectedDate="{Binding Nextverificationdate}">
                    <DatePicker.Resources>
                        <Style TargetType="Calendar">
                            <Setter Property="Language" Value="ru-RU"/>
                        </Style>
                        <Style TargetType="CalendarItem">
                            <Setter Property="Language" Value="ru-RU"/>
                        </Style>
                    </DatePicker.Resources>
                </DatePicker>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="3" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                       FontSize="20" FontWeight="DemiBold"
                       Margin="14, 10, 0, 10">
                Экспулатация
            </TextBlock>
            <Border Height="1"
                    Grid.Row="0" Grid.ColumnSpan="2"
                    Background="#707070"
                    VerticalAlignment="Bottom"
                    Margin="14, 0, 0, 0"/>
            <CheckBox Grid.Row="1" Grid.Column="0"
                      Margin="14, 15, 0, 0"
                      IsThreeState="False" FontWeight="DemiBold"
                      Height="20" Content="Непригодный"/>
            <StackPanel Grid.Row="2" Grid.Column="0">
                <TextBlock FontSize="12" FontWeight="DemiBold"
                           Margin="14, 15, 0, 0"
                           Foreground="#707070">
                    Место установки/эксплуатации
                </TextBlock>
                <TextBox x:Name="DeviceInstallationLocation" Margin="14, 4, 7, 0" 
                         hс:BorderElement.CornerRadius="7" 
                         BorderBrush="#c7c7c9" Background="#FFE0E0E0"
                         Text="{Binding Installationlocation}"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1">
                <TextBlock FontSize="12" FontWeight="DemiBold"
                           Margin="7, 15, 0, 0"
                           Foreground="#707070">
                    Ответственное лицо
                </TextBlock>
                <TextBox x:Name="DeviceUser" Margin="7, 4, 0, 0" 
                         hс:BorderElement.CornerRadius="7" 
                         BorderBrush="#c7c7c9" Background="#FFE0E0E0"
                         Text="{Binding UserId.GetFullName}"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.ColumnSpan="2">
                <TextBlock FontSize="12" FontWeight="DemiBold"
                           Margin="7, 15, 0, 0"
                           Foreground="#707070">
                    Примечание
                </TextBlock>
                <TextBox x:Name="DeviceNote" Margin="7, 4, 0, 0" 
                         hс:BorderElement.CornerRadius="7" 
                         Height="70"
                         BorderBrush="#c7c7c9" Background="#FFE0E0E0"
                         Text="{Binding Note}"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       FontSize="20" FontWeight="DemiBold"
                       Margin="14, 10, 0, 10">
                Документы и файлы
            </TextBlock>
            <Border Height="1"
                    Grid.Row="0"
                    Background="#707070"
                    VerticalAlignment="Bottom"
                    Margin="14, 0, 0, 0"/>
            <Button Grid.Row="1" hс:BorderElement.CornerRadius="7"
                    Margin="14, 0, 0, 0" FontWeight="DemiBold"
                    HorizontalAlignment="Left"
                    Width="130" Background="#eceef2">
                Загрузить файлы
            </Button>
            
        </Grid>
    </Grid>
</Window>
