<Window x:Class="MetryxWPF.AddDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MetryxWPF"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Title="AddDeviceWindow" Height="600" Width="550" 
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" FontSize="20" Foreground="Black"
                       Margin="14, 5, 14, 0" FontWeight="DemiBold">
                Добавить прибор
            </TextBlock>
            <TextBlock Grid.Row="1" FontSize="15" Foreground="#707070"
                       Margin="14, 5, 14, 5">
                Заполните обязательные поля прибора
            </TextBlock>
            <Border Height="1"
                    Width="Auto"
                    Grid.Row="1"
                    Background="#707070"
                    VerticalAlignment="Bottom"/>
        </Grid>
        <StackPanel Grid.Row="1">
            <TextBlock FontSize="12" FontWeight="DemiBold" 
                       Margin="14, 10, 0, 4">
                <Run>Наименование прибора</Run>
                <Run Foreground="Red">*</Run>
            </TextBlock>
            <TextBox x:Name="DeviceName" Margin="14, 0, 14, 0" 
                     hc:BorderElement.CornerRadius="7" 
                     BorderBrush="#c7c7c9" Background="#FFE0E0E0">
            </TextBox>
        </StackPanel>
        <StackPanel Grid.Row="2">
            <TextBlock FontSize="12" FontWeight="DemiBold" 
                       Margin="14, 10, 0, 4">
                <Run>Тип прибора</Run>
                <Run Foreground="Red">*</Run>
            </TextBlock>
            <ComboBox x:Name="DeviceType" Margin="14, 0, 14, 0" 
                      hc:BorderElement.CornerRadius="7" 
                      BorderBrush="#c7c7c9" Background="#FFE0E0E0"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"/>
        </StackPanel>
        <StackPanel Grid.Row="3">
            <TextBlock FontSize="12" FontWeight="DemiBold" 
                       Margin="14, 10, 0, 4">
                <Run>Вид прибора</Run>
                <Run Foreground="Red">*</Run>
            </TextBlock>
            <ComboBox x:Name="DeviceSpecies" Margin="14, 0, 14, 0" 
                      hc:BorderElement.CornerRadius="7" 
                      BorderBrush="#c7c7c9" Background="#FFE0E0E0"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"/>
        </StackPanel>
        <StackPanel Grid.Row="4">
            <TextBlock FontSize="12" FontWeight="DemiBold" 
                       Margin="14, 10, 0, 4">
                <Run>Заводской номер</Run>
                <Run Foreground="Red">*</Run>
            </TextBlock>
            <TextBox x:Name="DeviceSerialNumber" Margin="14, 0, 14, 0" 
                     hc:BorderElement.CornerRadius="7" 
                     BorderBrush="#c7c7c9" Background="#FFE0E0E0">
            </TextBox>
        </StackPanel>
        <StackPanel Grid.Row="5">
            <TextBlock FontSize="12" FontWeight="DemiBold" 
                       Margin="14, 10, 0, 4">
                <Run>Дата выпуска</Run>
                <Run Foreground="Red">*</Run>
            </TextBlock>
            <DatePicker x:Name="DeviceReleaseDate" Margin="14, 0, 14, 0"
                        hc:BorderElement.CornerRadius="7" 
                        BorderBrush="#c7c7c9"
                        BorderThickness="1"
                        Background="#FFE0E0E0"
                        IsDropDownOpen="False" SelectedDateFormat="Short">
                <DatePicker.Resources>
                    <Style TargetType="Calendar">
                        <Setter Property="Language" Value="ru-RU"/>
                    </Style>
                    <Style TargetType="CalendarItem">
                        <Setter Property="Language" Value="ru-RU"/>
                    </Style>
                </DatePicker.Resources>
            </DatePicker>
        </StackPanel>
        <StackPanel Grid.Row="6">
            <TextBlock FontSize="12" FontWeight="DemiBold" 
                       Margin="14, 10, 0, 4">
                <Run>Дата последней поверки</Run>
                <Run Foreground="Red">*</Run>
            </TextBlock>
            <DatePicker x:Name="DeviceLastverificationDate" Margin="14, 0, 14, 0"
                hc:BorderElement.CornerRadius="7" 
                BorderBrush="#c7c7c9"
                BorderThickness="1"
                Background="#FFE0E0E0"
                IsDropDownOpen="False" SelectedDateFormat="Short">
                <DatePicker.Resources>
                    <Style TargetType="Calendar">
                        <Setter Property="Language" Value="ru-RU"/>
                    </Style>
                    <Style TargetType="CalendarItem">
                        <Setter Property="Language" Value="ru-RU"/>
                    </Style>
                </DatePicker.Resources>
            </DatePicker>
        </StackPanel>
        <Grid Grid.Row="7" Margin="0, 20, 0, 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Foreground="White" Background="#030213"
                    HorizontalAlignment="Stretch" Height="40" Click="SaveButton_Click"
                    Margin="14, 0, 10, 10" hc:BorderElement.CornerRadius="7">
                Сохранить
            </Button>
            <Button Grid.Column="1" Foreground="Black" Background="#eceef2"
                    HorizontalAlignment="Stretch" Height="40" Click="CancelButton_Click"
                    Margin="14, 0, 10, 10" hc:BorderElement.CornerRadius="7">
                Отмена
            </Button>
        </Grid>
    </Grid>
</Window>
